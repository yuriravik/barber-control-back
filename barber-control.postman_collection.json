    {
      "name": "💳 Pagamentos",
      "item": [
        {
          "name": "Registrar Pagamento",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
